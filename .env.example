# ===========================================
# CVScholar - Environment Configuration
# Copy this to .env and fill in your values
# ===========================================

# --- App ---
APP_ENV=production
APP_DEBUG=false
APP_URL=http://your-domain.com

# --- MySQL (used by docker-compose for the db container) ---
MYSQL_ROOT_PASSWORD=change_this_root_password_123
MYSQL_DATABASE=academic_cv
MYSQL_USER=cvscholar
MYSQL_PASSWORD=change_this_db_password_456

# --- PHP App DB Connection (must match above) ---
DB_HOST=db
DB_PORT=3306
DB_NAME=academic_cv
DB_USER=cvscholar
DB_PASS=change_this_db_password_456

# Security
PASSWORD_MIN_LENGTH=8
PASSWORD_REQUIRE_UPPERCASE=True
PASSWORD_REQUIRE_LOWERCASE=True
PASSWORD_REQUIRE_DIGIT=True
PASSWORD_REQUIRE_SPECIAL=False
SESSION_COOKIE_SECURE=False  # Set True in production with HTTPS
SESSION_COOKIE_HTTPONLY=True
SESSION_COOKIE_SAMESITE=Lax

# Admin
ADMIN_EMAIL=admin@yourdomain.com
ADMIN_PASSWORD=change-this-password

# Docker
COMPOSE_PROJECT_NAME=academic-cv-saas

# Production Only
# SSL_CERT_PATH=/etc/letsencrypt/live/yourdomain.com/fullchain.pem
# SSL_KEY_PATH=/etc/letsencrypt/live/yourdomain.com/privkey.pem
